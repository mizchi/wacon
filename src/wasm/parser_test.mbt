///|
// hello.wasm binary (compiled from hello.wat)
// Manually embedded for testing
fn hello_wasm() -> Bytes {
  // Generated by: wasm-tools parse hello.wat -o hello.wasm
  // 166 bytes
  Bytes::from_array([
    b'\x00', b'\x61', b'\x73', b'\x6D', // magic: \0asm
     b'\x01', b'\x00', b'\x00', b'\x00', // version: 1
    // Type section (id=1)
     b'\x01', b'\x0C', b'\x02', // section, size=12, count=2
     b'\x60', b'\x04', b'\x7F', b'\x7F', b'\x7F', b'\x7F', b'\x01', b'\x7F', // type 0: (i32,i32,i32,i32)->i32
     b'\x60', b'\x00', b'\x00', // type 1: ()->()
    // Import section (id=2)
     b'\x02', b'\x23', b'\x01', // section, size=35, count=1
     b'\x16', // name len=22
     b'\x77', b'\x61', b'\x73', b'\x69', b'\x5F', b'\x73', b'\x6E', b'\x61', b'\x70',
    b'\x73', b'\x68', b'\x6F', b'\x74', b'\x5F', b'\x70', b'\x72', b'\x65', b'\x76',
    b'\x69', b'\x65', b'\x77', b'\x31', // "wasi_snapshot_preview1"
     b'\x08', // name len=8
     b'\x66', b'\x64', b'\x5F', b'\x77', b'\x72', b'\x69', b'\x74', b'\x65', // "fd_write"
     b'\x00', b'\x00', // kind=func, type_idx=0
    // Function section (id=3)
     b'\x03', b'\x02', b'\x01', b'\x01', // section, size=2, count=1, type_idx=1
    // Memory section (id=5)
     b'\x05', b'\x03', b'\x01', b'\x00', b'\x01', // section, size=3, count=1, flags=0, min=1
    // Export section (id=7)
     b'\x07', b'\x13', b'\x02', // section, size=19, count=2
     b'\x06', b'\x6D', b'\x65', b'\x6D', b'\x6F', b'\x72', b'\x79', b'\x02', b'\x00', // "memory", kind=memory, idx=0
     b'\x06', b'\x5F', b'\x73', b'\x74', b'\x61', b'\x72', b'\x74', b'\x00', b'\x01', // "_start", kind=func, idx=1
    // Code section (id=10)
     b'\x0A', b'\x1E', b'\x01', // section, size=30, count=1
     b'\x1C', // body size=28
     b'\x00', // 0 local blocks
     b'\x41', b'\x00', // i32.const 0
     b'\x41', b'\x08', // i32.const 8
     b'\x36', b'\x02', b'\x00', // i32.store align=2 offset=0
     b'\x41', b'\x04', // i32.const 4
     b'\x41', b'\x11', // i32.const 17
     b'\x36', b'\x02', b'\x00', // i32.store align=2 offset=0
     b'\x41', b'\x01', // i32.const 1
     b'\x41', b'\x00', // i32.const 0
     b'\x41', b'\x01', // i32.const 1
     b'\x41', b'\xE4', b'\x00', // i32.const 100
     b'\x10', b'\x00', // call 0
     b'\x1A', // drop
     b'\x0B', // end
    // Data section (id=11)
     b'\x0B', b'\x17', b'\x01', // section, size=23, count=1
     b'\x00', // flags=0 (active, memory 0)
     b'\x41', b'\x08', b'\x0B', // offset: i32.const 8, end
     b'\x11', // data length=17
     b'\x68', b'\x65', b'\x6C', b'\x6C', b'\x6F', b'\x20', b'\x66', b'\x72', b'\x6F',
    b'\x6D', b'\x20', b'\x77', b'\x61', b'\x63', b'\x6F', b'\x6E', b'\x0A', // "hello from wacon\n"
    // Custom section (name) - skipped by parser
     b'\x00', b'\x12', b'\x04', b'\x6E', b'\x61', b'\x6D', b'\x65', // "name"
     b'\x01', b'\x0B', b'\x01', b'\x00', b'\x08', b'\x66', b'\x64', b'\x5F', b'\x77',
    b'\x72', b'\x69', b'\x74', b'\x65', // func 0 = "fd_write"
  ])
}

///|
test "parse hello.wasm types" {
  let data = hello_wasm()
  guard @wasm.parse(data) is Some(m) else { fail("parse failed") }
  inspect(m.types.length(), content="2")
  // type 0: (i32,i32,i32,i32) -> i32
  inspect(m.types[0].params.length(), content="4")
  inspect(m.types[0].results.length(), content="1")
  // type 1: () -> ()
  inspect(m.types[1].params.length(), content="0")
  inspect(m.types[1].results.length(), content="0")
}

///|
test "parse hello.wasm imports" {
  let data = hello_wasm()
  guard @wasm.parse(data) is Some(m) else { fail("parse failed") }
  inspect(m.imports.length(), content="1")
  inspect(m.imports[0].module_name, content="wasi_snapshot_preview1")
  inspect(m.imports[0].field_name, content="fd_write")
}

///|
test "parse hello.wasm exports" {
  let data = hello_wasm()
  guard @wasm.parse(data) is Some(m) else { fail("parse failed") }
  inspect(m.exports.length(), content="2")
  inspect(m.exports[0].name, content="memory")
  inspect(m.exports[1].name, content="_start")
}

///|
test "parse hello.wasm memory" {
  let data = hello_wasm()
  guard @wasm.parse(data) is Some(m) else { fail("parse failed") }
  inspect(m.memories.length(), content="1")
  inspect(m.memories[0].min, content="1")
}

///|
test "parse hello.wasm code" {
  let data = hello_wasm()
  guard @wasm.parse(data) is Some(m) else { fail("parse failed") }
  inspect(m.codes.length(), content="1")
  inspect(m.codes[0].locals.length(), content="0")
  // Should have: i32.const 0, i32.const 8, i32.store, ...
  assert_true(m.codes[0].code.length() > 0)
}

///|
test "parse hello.wasm data" {
  let data = hello_wasm()
  guard @wasm.parse(data) is Some(m) else { fail("parse failed") }
  inspect(m.datas.length(), content="1")
  inspect(m.datas[0].data.length(), content="17")
}

///|
test "parse hello.wasm functions" {
  let data = hello_wasm()
  guard @wasm.parse(data) is Some(m) else { fail("parse failed") }
  inspect(m.functions.length(), content="1")
  inspect(m.functions[0], content="1") // type index 1
}
